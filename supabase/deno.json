{
  "compilerOptions": {
    "lib": ["deno.unstable", "dom", "dom.iterable", "dom.asynciterable"],
    "noImplicitAny": false
  },
  "nodeModulesDir": "auto",
  "lint": {
    "files": {
      "include": ["functions/"]
    },
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-explicit-any"]
    }
  },
  "fmt": {
    "files": {
      "include": ["functions/"]
    },
    "options": {
      "useTabs": true,
      "lineWidth": 80,
      "indentWidth": 4,
      "singleQuote": false
    }
  }
}
